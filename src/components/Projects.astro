---
import { siteConfig } from "../config";
---

<section id="projects" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <p class="section-label mb-4">Projects</p>
    <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-medium text-charcoal mb-16 gold-line">
      Systems I've designed &amp; shipped
    </h2>

    <div class="grid md:grid-cols-2 gap-6">
      {siteConfig.projects.map((project: { name: string; description: string; link: string; skills: string[] }, i: number) => (
        <div
          class="fade-in group relative border border-divider p-8 hover:border-gold/40 transition-all duration-500 hover:shadow-[0_8px_40px_-12px_rgba(201,168,76,0.12)]"
          style={`--i:${i}`}
        >
          <!-- Subtle top-left corner accent -->
          <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-gold/0 group-hover:border-gold/30 transition-all duration-500" aria-hidden="true"></div>
          <div class="flex items-start justify-between mb-5">
            <span class="font-[family-name:var(--font-mono)] text-[0.6rem] tracking-[0.18em] uppercase text-gold/60 group-hover:text-gold transition-colors duration-300">
              {String(i + 1).padStart(2, "0")}
            </span>
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-[0.65rem] font-medium tracking-[0.1em] uppercase text-slate hover:text-gold transition-colors duration-200"
              >
                View <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10" /></svg>
              </a>
            )}
          </div>
          <h3 class="font-[family-name:var(--font-display)] text-xl font-medium text-charcoal mb-3 group-hover:text-charcoal transition-colors">
            {project.name}
          </h3>
          <p class="text-[0.85rem] leading-relaxed text-charcoal/60 mb-6">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.skills.map((skill: string) => (
              <span class="font-[family-name:var(--font-mono)] text-[0.58rem] tracking-[0.08em] uppercase px-2.5 py-1 bg-cream/70 text-charcoal/60 border border-divider/50">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
