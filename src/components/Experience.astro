---
import { siteConfig } from "../config";
---

<section id="experience" class="relative py-28 bg-charcoal text-warm-white overflow-hidden">
  <!-- Decorative: vertical rule -->
  <div class="absolute top-0 left-[calc(50%-1px)] w-px h-full bg-gradient-to-b from-transparent via-divider-dark/40 to-transparent hidden lg:block" aria-hidden="true"></div>
  <div class="max-w-6xl mx-auto px-6 relative">
    <p class="section-label mb-4">Experience</p>
    <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-medium mb-16 gold-line">
      Where I've built &amp; led
    </h2>

    <div class="space-y-16">
      {siteConfig.experience.map((exp: { company: string; title: string; dateRange: string; bullets: string[] }, i: number) => (
        <div class="fade-in grid lg:grid-cols-[280px_1fr] gap-8 lg:gap-12" style={`--i:${i}`}>
          <!-- Left: Meta -->
          <div class="lg:text-right">
            <span class="font-[family-name:var(--font-mono)] text-[0.65rem] tracking-[0.15em] uppercase text-gold">
              {exp.dateRange}
            </span>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-medium text-warm-white mt-2">
              {exp.company}
            </h3>
            <p class="text-sm text-slate-light mt-1">{exp.title}</p>
          </div>
          <!-- Right: Bullets -->
          <div class="lg:border-l lg:border-divider-dark lg:pl-12">
            <ul class="space-y-4">
              {exp.bullets.map((bullet: string) => (
                <li class="flex gap-3 text-[0.9rem] leading-relaxed text-warm-white/75">
                  <span class="text-gold mt-1.5 shrink-0">—</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- Education -->
    {siteConfig.education && siteConfig.education.length > 0 && (
      <div class="mt-20 pt-12 border-t border-divider-dark">
        <p class="section-label mb-8">Education</p>
        <div class="space-y-10">
          {siteConfig.education.map((edu: { school: string; degree: string; dateRange: string; achievements: string[] }) => (
            <div class="fade-in grid lg:grid-cols-[280px_1fr] gap-8 lg:gap-12">
              <div class="lg:text-right">
                <span class="font-[family-name:var(--font-mono)] text-[0.65rem] tracking-[0.15em] uppercase text-gold">
                  {edu.dateRange}
                </span>
                <h3 class="font-[family-name:var(--font-display)] text-xl font-medium text-warm-white mt-2">
                  {edu.school}
                </h3>
              </div>
              <div class="lg:border-l lg:border-divider-dark lg:pl-12">
                <p class="text-[0.9rem] text-warm-white/75">{edu.degree}</p>
                <ul class="mt-3 space-y-2">
                  {edu.achievements.map((a: string) => (
                    <li class="flex gap-3 text-sm text-warm-white/60">
                      <span class="text-gold mt-0.5 shrink-0">—</span>
                      <span>{a}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        {/* Certifications */}
        {siteConfig.certifications && siteConfig.certifications.length > 0 && (
          <div class="mt-12 pt-10 border-t border-divider-dark">
            <p class="section-label mb-6">Certifications</p>
            <div class="flex flex-wrap gap-3">
              {siteConfig.certifications.map((cert: string) => (
                <span class="font-[family-name:var(--font-mono)] text-[0.7rem] tracking-wide px-4 py-2 border border-divider-dark text-warm-white/60">
                  {cert}
                </span>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </div>
</section>
