---
import { siteConfig } from "../config";
---

<section class="py-0">
  <div class="max-w-6xl mx-auto px-6">
    <div class="border-y border-divider py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
        {siteConfig.stats.map((stat: { value: string; label: string; detail: string }, i: number) => (
          <div class="fade-in group text-center md:text-left" style={`--i:${i}`}>
            <div class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold tracking-tight">
              <span class="bg-gradient-to-br from-charcoal via-charcoal to-gold/60 bg-clip-text text-transparent">{stat.value}</span>
            </div>
            <div class="text-[0.65rem] font-semibold tracking-[0.14em] uppercase text-charcoal/80 mt-3">
              {stat.label}
            </div>
            <div class="text-[0.8rem] text-slate mt-1">
              {stat.detail}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
