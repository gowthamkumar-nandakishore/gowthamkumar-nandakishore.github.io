---
import { siteConfig } from "../config";
---

<section id="about" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-[1fr_320px] gap-16">
      <!-- Main text -->
      <div class="fade-in">
        <p class="section-label mb-4">About</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-medium text-charcoal mb-8 gold-line">
          Engineering leadership<br />meets deep technical craft
        </h2>
        <div class="space-y-5 text-[0.95rem] leading-[1.8] text-charcoal/75">
          <p>
            I am a senior engineer with <strong class="text-charcoal font-medium">12 years of experience</strong> building systems that scale — from enterprise financial platforms processing millions of daily transactions, to Generative AI document parsing pipelines at WiseTech Global (CargoWise).
          </p>
          <p>
            Currently I own two production AI services inside an end-to-end document intelligence pipeline. The system uses <strong class="text-charcoal font-medium">zero-shot LLM extraction</strong>, in-context learning via AWS Bedrock (Claude Sonnet), FAISS vector search, and a closed human-feedback loop to automatically extract fields from logistics documents at enterprise scale.
          </p>
          <p>
            I combine deep systems engineering with genuine people leadership — having managed teams of up to <strong class="text-charcoal font-medium">12 engineers</strong> including IIT graduates across India and the UK, with full engineering management responsibilities: performance reviews, hiring, 1:1s, conflict resolution, and career growth.
          </p>
          <p>
            I hold an <strong class="text-charcoal font-medium">M.Tech from BITS Pilani</strong> and enjoy working at companies building ambitious, high-impact products.
          </p>
        </div>
      </div>
      <!-- Sidebar highlights -->
      <aside class="fade-in flex flex-col gap-6 lg:border-l lg:border-divider lg:pl-10">
        <div>
          <span class="font-[family-name:var(--font-mono)] text-[0.65rem] tracking-[0.15em] uppercase text-gold">Specialisation</span>
          <p class="text-sm text-charcoal mt-1 font-medium">Generative AI · RAG Pipelines · LLM Infrastructure</p>
        </div>
        <div class="w-full h-px bg-divider"></div>
        <div>
          <span class="font-[family-name:var(--font-mono)] text-[0.65rem] tracking-[0.15em] uppercase text-gold">Leadership</span>
          <p class="text-sm text-charcoal mt-1 font-medium">Engineering Management · Hiring · Cross-timezone Teams</p>
        </div>
        <div class="w-full h-px bg-divider"></div>
        <div>
          <span class="font-[family-name:var(--font-mono)] text-[0.65rem] tracking-[0.15em] uppercase text-gold">Domain</span>
          <p class="text-sm text-charcoal mt-1 font-medium">Document Intelligence · Financial Leasing · Logistics</p>
        </div>
        <div class="w-full h-px bg-divider"></div>
        <div>
          <span class="font-[family-name:var(--font-mono)] text-[0.65rem] tracking-[0.15em] uppercase text-gold">Stack</span>
          <p class="text-sm text-charcoal mt-1 font-medium">Python · C# · AWS · FastAPI · .NET</p>
        </div>
      </aside>
    </div>
  </div>
</section>
