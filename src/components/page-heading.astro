---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<div class="mb-10">
  <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-2">
    {title}
  </h1>
  {description && (
    <p class="text-neutral-500 dark:text-neutral-400 text-lg">
      {description}
    </p>
  )}
</div>
