---
import { siteConfig } from "../config";
---

<section id="contact" class="relative py-28 bg-charcoal text-warm-white overflow-hidden">
  <!-- Decorative: abstract corner accent -->
  <div class="absolute top-0 right-0 w-64 h-64 opacity-[0.03]" aria-hidden="true">
    <svg viewBox="0 0 200 200" fill="none"><circle cx="200" cy="0" r="200" stroke="currentColor" stroke-width="0.5" /><circle cx="200" cy="0" r="140" stroke="currentColor" stroke-width="0.5" /><circle cx="200" cy="0" r="80" stroke="currentColor" stroke-width="0.5" /></svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 relative">
    <div class="max-w-2xl">
      <p class="section-label mb-4">Contact</p>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-medium mb-6 gold-line">
        Let's build something<br />ambitious together
      </h2>
      <p class="text-[0.95rem] leading-relaxed text-warm-white/50 mb-14">
        If you're building something ambitious, I'd love to hear about it.
      </p>

      <div class="grid sm:grid-cols-2 gap-10">
        <a
          href={`mailto:${siteConfig.social.email}`}
          class="group flex items-start gap-4 p-5 border border-divider-dark rounded-sm hover:border-gold/30 transition-all duration-300"
        >
          <div class="w-10 h-10 flex items-center justify-center border border-gold/30 rounded-sm shrink-0 group-hover:bg-gold/10 transition-colors duration-300">
            <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
          </div>
          <div>
            <span class="font-[family-name:var(--font-mono)] text-[0.6rem] tracking-[0.18em] uppercase text-gold block mb-1.5">Email</span>
            <span class="text-sm text-warm-white/70 group-hover:text-gold transition-colors duration-300">
              {siteConfig.social.email}
            </span>
          </div>
        </a>

        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-4 p-5 border border-divider-dark rounded-sm hover:border-gold/30 transition-all duration-300"
        >
          <div class="w-10 h-10 flex items-center justify-center border border-gold/30 rounded-sm shrink-0 group-hover:bg-gold/10 transition-colors duration-300">
            <svg class="w-4 h-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.928-1.474a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.343 8.17" /></svg>
          </div>
          <div>
            <span class="font-[family-name:var(--font-mono)] text-[0.6rem] tracking-[0.18em] uppercase text-gold block mb-1.5">LinkedIn</span>
            <span class="text-sm text-warm-white/70 group-hover:text-gold transition-colors duration-300">
              linkedin.com/in/gowthamkumarn
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
