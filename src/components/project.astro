---
interface Props {
  name: string;
  description: string;
  url: string;
  tags?: string[];
  badge?: string;
  badgeUrl?: string;
  gradient?: string;
}

const {
  name,
  description,
  url,
  tags = [],
  badge,
  badgeUrl,
  gradient = "from-neutral-700 to-neutral-900",
} = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex flex-col rounded-2xl duration-300 ease-out"
>
  <!-- Dashed border hover effect (aria style) -->
  <span
    class="absolute inset-0 z-20 block w-full h-full duration-300 ease-out bg-transparent border border-transparent border-dashed group-hover:-translate-x-1 group-hover:-translate-y-1 group-hover:border-neutral-300 dark:group-hover:border-neutral-600 group-hover:bg-white dark:group-hover:bg-neutral-950 rounded-2xl"
  ></span>
  <span
    class="absolute inset-0 z-10 block w-full h-full duration-300 ease-out border border-dashed rounded-2xl border-neutral-300 dark:border-neutral-700 group-hover:translate-x-1 group-hover:translate-y-1"
  ></span>

  <!-- Card content -->
  <span
    class="relative z-30 block duration-300 ease-out group-hover:-translate-x-1 group-hover:-translate-y-1 p-5"
  >
    <!-- Gradient header -->
    <span
      class={`block w-full h-28 rounded-xl bg-gradient-to-br ${gradient} flex items-end p-4 mb-4`}
    >
      <span class="text-xl font-bold text-white font-mono tracking-tight">
        {name}
      </span>
    </span>

    <!-- Title + badge -->
    <span class="flex items-center gap-2 mb-2 flex-wrap">
      <span
        class="text-base font-semibold text-neutral-900 dark:text-neutral-100"
      >
        {name}
      </span>
      {badge && (
        <a
          href={badgeUrl || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs px-2 py-0.5 rounded-full bg-indigo-100 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300 font-mono hover:bg-indigo-200 dark:hover:bg-indigo-900/50 transition-colors relative z-40"
          onclick="event.stopPropagation();"
        >
          {badge}
        </a>
      )}
      <!-- Arrow -->
      <svg
        class="w-4 h-4 ml-auto text-neutral-400 group-hover:text-neutral-900 dark:group-hover:text-neutral-100 group-hover:translate-x-1 duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M7 17L17 7M17 7H7M17 7v10"></path>
      </svg>
    </span>

    <!-- Description -->
    <span class="text-sm text-neutral-600 dark:text-neutral-400 block mb-3">
      {description}
    </span>

    <!-- Tags -->
    {
      tags.length > 0 && (
        <span class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="text-xs px-2 py-0.5 rounded-md bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 font-mono">
              {tag}
            </span>
          ))}
        </span>
      )
    }
  </span>
</a>
