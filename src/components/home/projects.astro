---
import Project from "../project.astro";
import projects from "../../collections/projects.json";

const featured = projects.slice(0, 4);
---

<section>
  <div class="flex items-center justify-between mb-6">
    <h2
      class="text-xl font-bold text-neutral-900 dark:text-neutral-100"
    >
      Projects & Research
    </h2>
    <a
      href="/projects"
      class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
    >
      View all →
    </a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {
      featured.map((project) => (
        <Project
          name={project.name}
          description={project.description}
          url={project.url}
          tags={project.tags}
          badge={project.badge}
          badgeUrl={project.badgeUrl}
        />
      ))
    }
  </div>
</section>
