---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="flex items-center gap-4 py-10">
  <div class="flex-1 h-px bg-neutral-200 dark:bg-neutral-800"></div>
  <span
    class="text-xs uppercase tracking-widest text-neutral-400 dark:text-neutral-500 whitespace-nowrap"
  >
    {text}
  </span>
  <div class="flex-1 h-px bg-neutral-200 dark:bg-neutral-800"></div>
</div>
